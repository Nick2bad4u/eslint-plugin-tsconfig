{
    "$schema": "https://www.schemastore.org/tsconfig.json",
    "compilerOptions": {
        "ignoreDeprecations": "6.0",
        "isolatedDeclarations": false,
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ES2024"
        ],
        "module": "ESNext",
        "moduleResolution": "bundler",
        "noEmit": true,
        "skipLibCheck": true,
        "strict": true,
        "target": "ES2024",
        "types": [
            "node"
        ]
    },
    "exclude": [
        ".docusaurus",
        "build",
        "node_modules"
    ],
    "extends": [
        "../../tsconfig.json",
        "@docusaurus/tsconfig"
    ],
    "include": [
        "docusaurus.config.ts",
        "sidebars.ts",
        "sidebars.rules.ts",
        "src/**/*"
    ]
}
